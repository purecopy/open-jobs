{
  "planDirectory": "./docs/plans",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "npm run fix -- --skip=correctness/noUnusedImports",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "npm run typecheck",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ]
  }
}
